{
  "name": "daml-lf-viability-spike",
  "version": "0.1.0",
  "private": true,
  "description": "Research spike to validate Daml-LF DALF/DAR decode viability for static analysis in Node.js.",
  "license": "MIT",
  "type": "module",
  "main": "dist/dalf_probe.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist output",
    "probe": "ts-node src/dalf_probe.ts",
    "probe:node": "node src/dalf_probe.ts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "daml",
    "dalf",
    "dar",
    "protobuf",
    "static-analysis",
    "canton"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
