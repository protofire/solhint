{
  "name": "solhint",
  "version": "6.2.1",
  "description": "Solidity Code Linter",
  "main": "lib/index.js",
  "keywords": [
    "solidity",
    "linter",
    "security-scanner",
    "ethereum",
    "ast",
    "developer-tools",
    "code-quality",
    "smart-contracts"
  ],
  "homepage": "https://protofire.github.io/solhint/",
  "repository": "https://github.com/protofire/solhint",
  "scripts": {
    "exec-tests": "nyc mocha --recursive && nyc report",
    "test:coverage": "npm run exec-tests",
    "test": "mocha --recursive",
    "lint": "eslint .",
    "gen-rules": "node scripts/generate-rulesets.js && prettier --write conf/rulesets",
    "docs": "node scripts/generate-rule-docs.js",
    "prepublishOnly": "npm run lint && npm run test && npm run gen-rules && npm run docs",
    "local:e2e": "bash -c 'set -xeuo pipefail && rm solhint*tgz -f && npm pack && npm i -g solhint*tgz && (npm run ci:e2e);npm uninstall -g solhint'",
    "install:global": "bash -c 'set -xeuo pipefail && rm solhint*tgz -f && npm pack && npm i -g solhint*tgz'",
    "uninstall:global": "npm uninstall -g solhint",
    "ci:e2e": "mocha e2e/test.js e2e/formatters-test.js e2e/autofix-test.js --timeout 10000"
  },
  "bin": {
    "solhint": "solhint.js"
  },
  "files": [
    "/conf/",
    "/lib/",
    "/solhint.js"
  ],
  "author": "Ilya Drabenia <ilya.drobenya@gmail.com>",
  "contributors": [
    "Diego Bale <diego.bale@protofire.io>"
  ],
  "license": "MIT",
  "dependencies": {
    "@solidity-parser/parser": "^0.20.2",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ast-parents": "^0.0.1",
    "better-ajv-errors": "^2.0.2",
    "chalk": "^4.1.2",
    "commander": "^10.0.0",
    "cosmiconfig": "^8.0.0",
    "fast-diff": "^1.2.0",
    "glob": "^13.0.6",
    "ignore": "^5.2.4",
    "js-yaml": "^4.1.0",
    "latest-version": "^7.0.0",
    "lodash": "^4.17.21",
    "pluralize": "^8.0.0",
    "semver": "^7.5.2",
    "table": "^6.8.1",
    "text-table": "^0.2.0"
  },
  "devDependencies": {
    "assert": "^2.0.0",
    "chai": "^4.3.7",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.0.0",
    "get-stream": "^6.0.0",
    "markdown-table": "^2.0.0",
    "mocha": "^10.2.0",
    "mocha-lcov-reporter": "^1.3.0",
    "nyc": "^15.1.0",
    "rimraf": "^6.1.3",
    "shelljs": "^0.8.5",
    "sinon": "^20.0.0",
    "spawn-sync": "^2.0.0",
    "strip-ansi": "6",
    "solhint-plugin-prettier": "^0.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "prettier": "^3.0.0"
  },
  "overrides": {
    "picomatch": "^2.3.2",
    "flatted": "^3.4.2",
    "minimatch@^3.0.0": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@^5.0.0": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@^10.0.0": {
      "brace-expansion": "5.0.5"
    }
  }
}
